<Window x:Class="Group4337._4337_Moryashova"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="_4337_Moryashova" Height="450" Width="800">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0">

        <TextBlock Text="Моряшова Ксения, 19 лет"
                   FontSize="16" 
                   HorizontalAlignment="Center" 
                   TextAlignment="Center"
                   Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Импорт данных" 
                    Click="BtnImport_Click" 
                    Margin="5,0" 
                    Width="150"/>

            <Button Content="Экспорт в Excel" 
                    Click="BtnExport_Click" 
                    Margin="5,0" 
                    Width="150"/>
        </StackPanel>

    </StackPanel>
</Window>